generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 블로그 읽기 전용 모델 (clsedu.co.kr 프론트엔드용)

model BlogPost {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  summary          String?
  content          Json
  contentHtml      String?       @map("content_html")
  featuredImageUrl String?       @map("featured_image_url")
  status           BlogStatus    @default(DRAFT)
  authorId         String        @map("author_id")
  categoryId       String?       @map("category_id")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  ogImageUrl       String?       @map("og_image_url")
  keywords         String?
  canonicalUrl     String?       @map("canonical_url")
  structuredData   Json?         @map("structured_data")
  publishedAt      DateTime?     @map("published_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  author           User          @relation(fields: [authorId], references: [id])
  category         BlogCategory? @relation(fields: [categoryId], references: [id])
  tags             BlogPostTag[]

  @@map("blog_posts")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

// users 테이블: 인증 및 블로그 작성자 정보 활용 구조로 확대
model User {
  id        String     @id @default(cuid())
  name      String
  email     String?    @unique
  phone     String?    @unique
  password  String?    @map("password_hash")
  role      Role       @default(STUDENT)
  avatarUrl String?    @map("avatar_url")

  blogPosts              BlogPost[]
  courseClassEnrollments CourseClassStudent[]  @relation("StudentCourseClasses")
  courseClassTeachers    CourseClassTeacher[]  @relation("TeacherCourseClasses")
  payments               Payment[]
  enrollments            Enrollment[]
  notificationRecipients NotificationRecipient[]

  @@map("users")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  amount      Int      @default(0)
  method      String?
  status      String   @default("PAID")
  paymentDate DateTime @map("payment_date")
  remarks     String?
  user        User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Enrollment {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  className      String?   @map("class_name")
  studentStatus  String?   @map("student_status")
  enrollmentDate DateTime? @map("enrollment_date")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  user           User      @relation(fields: [userId], references: [id])

  @@map("enrollments")
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id    String        @id @default(cuid())
  name  String        @unique
  slug  String        @unique
  posts BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  postId String   @map("post_id")
  tagId  String   @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── 수업 관련 모델 (읽기 전용, app.clsedu.co.kr DB 공유) ──────────────────────

model CourseClass {
  id        String               @id @default(cuid())
  name      String
  subjects  String[]
  levels    String[]
  color     String               @default("#639df2")
  isActive  Boolean              @default(true) @map("is_active")
  startDate DateTime?            @map("start_date")
  endDate   DateTime?            @map("end_date")
  schedules     ClassSchedule[]
  students      CourseClassStudent[]
  teachers      CourseClassTeacher[]
  notifications Notification[]

  @@map("course_classes")
}

model ClassSchedule {
  id        String      @id @default(cuid())
  classId   String      @map("class_id")
  dayOfWeek String      @map("day_of_week")
  startTime Float       @map("start_time")
  duration  Float
  class     CourseClass @relation(fields: [classId], references: [id])

  @@map("class_schedules")
}

model CourseClassStudent {
  classId    String      @map("class_id")
  studentId  String      @map("student_id")
  enrolledAt DateTime    @default(now()) @map("enrolled_at")
  class      CourseClass @relation(fields: [classId], references: [id])
  student    User        @relation("StudentCourseClasses", fields: [studentId], references: [id])

  @@id([classId, studentId])
  @@map("course_class_students")
}

model CourseClassTeacher {
  classId   String      @map("class_id")
  teacherId String      @map("teacher_id")
  class     CourseClass @relation(fields: [classId], references: [id])
  teacher   User        @relation("TeacherCourseClasses", fields: [teacherId], references: [id])

  @@id([classId, teacherId])
  @@map("course_class_teachers")
}

// ─── 알림장 모델 ─────────────────────────────────────────────────────────────

model Notification {
  id          String                  @id @default(cuid())
  title       String
  content     Json
  contentHtml String?                 @map("content_html")
  status      String                  @default("DRAFT")
  authorId    String                  @map("author_id")
  classId     String                  @map("class_id")
  publishedAt DateTime?               @map("published_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  author      User                    @relation(fields: [authorId], references: [id])
  class       CourseClass             @relation(fields: [classId], references: [id])
  recipients  NotificationRecipient[]

  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(cuid())
  notificationId String       @map("notification_id")
  userId         String       @map("user_id")
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("notification_recipients")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  phone     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("phone_verification_tokens")
}
